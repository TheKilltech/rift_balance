import * from "materials/scripts/pbr.material"
import * from "materials/scripts/buildings_base.material"

// ammo

material buildings/ammo/ammo_factory_energy_adv : buildings/destructible
{
	set_texture_alias albedo			materials/textures/buildings/main/cryo_station_albedo.dds
	set_texture_alias normal			materials/textures/buildings/main/cryo_station_normal.dds
	set_texture_alias packed			materials/textures/buildings/main/cryo_station_packed.dds
	set_texture_alias emissive			materials/textures/buildings/resources/ammo_factory_energy_adv_emissive.dds

	glow 5
}

