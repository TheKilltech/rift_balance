EntityBlueprint  // ammo_importer_low_calib_1_module
{
	name  "buildings/ammo/ammo_importer_low_calib_1_module"
	
	ResourceConverterDesc
	{
		in
		{
			GameplayResource
			{
				resource 			"energy"
				value				"40"
			}
		}
		
		out
		{
			GameplayResource
			{
				resource 			"ammo_tower_low_caliber"
				value				"2.4"
			}
			GameplayResource
			{
				resource 			"ammo_mech_low_caliber"
				value				"2.4"
				optional			"1"
			}
		}

		priority 4
		continous_local_production "1"
	}
	
