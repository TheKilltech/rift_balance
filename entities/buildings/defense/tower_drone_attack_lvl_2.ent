EntityBlueprint  // tower_drone_attack_lvl_2
{
	name				"buildings/defense/tower_drone_attack_lvl_2"
	base_blueprint 		"buildings/defense/tower_drone_attack"

	BuildingDesc
	{
		name 				"tower_drone_attack_lvl_2"
		bp   				"buildings/defense/tower_drone_attack_lvl_2"
		category 			"defense"
		localization_id		"gui/hud/building_name/tower_drone_attack"
		description			"gui/hud/building_description/tower_drone_attack"
		menu_icon			"gui/hud/building_icons/tower_drone_attack_lvl2"
		require 			"headquarters"
		building_group		"tower_drone_attack"
		buildable			"0"
		check_connect		"1"
		type				"tower"
		overrides			"tower,wall,pipe_ground,pipe_connector_t,pipe_connector_x,pipe_corner,pipeline,pipe_straight_windowless"
		upgrade				"buildings/defense/tower_drone_attack_lvl_3"
		exclude_terrain_types "magma_hot_ground,magma_very_hot_ground"

		costs
		{
			BuildingCostInfo
			{
				name "default"
				building_time 45
				building_cost
				{
					carbonium 	"400"
					steel 		"650"
					cobalt		"25"
					ai			"1"
				}
			}
		}		
	}

	ResourceConverterDesc
	{
		in
		{
			GameplayResource
			{
				resource 	"energy"
				value 		"15"
			}
			
			GameplayResource
			{
				resource 	"ammo_tower_low_caliber_lvl2" 
				value 		"0.2"
			}
			GameplayResource
			{
				resource 	"ammo_tower_energy_cell_lvl2" 
				value 		"0.1"
			}
		}

		out
		{
		}

		priority 6
	}
	
	LuaDesc
	{
		script "lua/buildings/drone_spawner_building.lua"
		
		database
		{
			cone_effect				string:"build_cone_3x3"
			cone_effect_sell 		string:"sell_big"

			drone_upkeep_modifier		float:"13.0"
			drone_full_search_interval	int:"5"
			drone_own_search_radius		float:"10"
			drone_search_radius			float:"55"
			drone_blueprint				string:"units/drones/drone_attack_physical_lvl_2"
			drone_attachments			string:"att_landing,att_landing_1"
			drone_per_spot				int:"2"
			drone_visible_on_spot		int:"0"
		}
	}
	
	HealthDesc
	{
		max_health 					"750"
		health 						"750"
		regeneration 				"0"
		regeneration_cooldown 		"0"
		 is_manual 1
		update_health_uniform 		"1"

		DestructionLevels
		{
			DestructionLevel
			{
				health 								"80"
				destroy_state_change_effect_group 	"80_transition"
				destroy_comp_delay 					"0.5"
				destroy_comp_event 					"80_destroy"
				destroyed_state_effect_group 		"80_state"
				destrucion_level_name 				"80"

			}
			DestructionLevel
			{
				health 								"60"
				destroy_state_change_effect_group 	"60_transition"
				destroy_comp_delay 					"0.5"
				destroy_comp_event 					"60_destroy"
				destroyed_state_effect_group 		"60_state"
				destrucion_level_name 				"60"
			}
			DestructionLevel
			{
				health 								"40"
				destroy_state_change_effect_group 	"40_transition"
				destroy_comp_delay 					"0.5"
				destroy_comp_event 					"40_destroy"
				destroyed_state_effect_group 		"40_state"
				destrucion_level_name 				"40"
			}
			DestructionLevel
			{
				health 								"20"
				destroy_state_change_effect_group 	"20_transition"
				destroy_comp_delay 					"0.5"
				destroy_comp_event 					"20_destroy"
				destroyed_state_effect_group 		"20_state"
				destrucion_level_name 				"20"
			}
			DestructionLevel
			{
				health 								"0"
				destroy_state_change_effect_group 	"0_transition"
				destroy_comp_delay 					"0.6"
				destroy_comp_event 					"default"
				//destroyed_state_effect_group 		"0_state"
			}			
		}
	}		

	MeshDesc
	{
		mesh 		"meshes/buildings/defense/tower_drone_attack_lvl_2.mesh"
		material 	"buildings/defense/tower_drone_attack_lvl_2"
	}

	SkeletonDesc
	{
		name "meshes/buildings/defense/tower_drone_attack_lvl_2"
	}

	EffectDesc
	{
		EffectBaseBlueprints
		{
			"buildings/effects_medium_base"
		}
		////////////////////////MISC/////////////////////////
		EffectGroup
		{
			group "vismod"
			enabled "1"
			Effects
			{
				Effect
				{
					blueprint	"effects/buildings_and_machines/pipe"
					bone 		"att_in_pipe"
				}
			}
		}
	}
}

