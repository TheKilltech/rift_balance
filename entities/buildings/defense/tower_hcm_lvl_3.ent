EntityBlueprint  // tower_hcm_lvl_3
{
	name  "buildings/defense/tower_hcm_lvl_3"
	base_blueprint "buildings/defense/tower_hcm_lvl_2"

	BuildingDesc
	{
		buildable			"0"
		name 				"tower_hcm_lvl_3"
		bp   				"buildings/defense/tower_hcm_lvl_3"
		category 			"defense"
		localization_id		"gui/hud/building_name/tower_hcm"
		description			"gui/hud/building_description/tower_hcm"
		menu_icon			"gui/hud/building_icons/tower_hcm_lvl3"
		require 			"headquarters"
		type				"tower"
		overrides			"tower,wall,pipe_ground,pipe_connector_t,pipe_connector_x,pipe_corner,pipeline,pipe_straight_windowless"
		exclude_terrain_types "magma_hot_ground,magma_very_hot_ground"
		check_connect		"1"
		condition			"NOT_BIOME"
		condition_value		"caverns"
		radius_name			"hcm"
		min_radius			"20"
		min_radius_effect	"voice_over/announcement/building_too_close"

		costs
		{
			BuildingCostInfo
			{
				name "default"
				building_time 60
				building_cost
				{
					carbonium 	"4000"
					alloys 		"3000"
					palladium	"800"
				}
			}
		}
	}

	ResourceConverterDesc
	{
		in
		{
			GameplayResource
			{
				resource 	"energy"
				value 		"75"
			}
			
			GameplayResource
			{
				resource 	"alloys"
				value 		"1"
			}
			
			GameplayResource
			{
				resource 	"ammo_tower_liquid_lvl3"
				value 		"2"
			}
			
			GameplayResource
			{
				resource 	"petroleum"
				value 		"40"
				family		"agent"
				attachment	"att_in_1"
			}
			
			GameplayResource
			{
				resource 	"flammable_gas"
				value 		"75"
				family		"agent"
				attachment	"att_in_1"
			}
		}

		out
		{
		}

		priority 6
	}

	HealthDesc
	{
		max_health 					"3000"
		health 						"3000"
		regeneration 				"0"
		regeneration_cooldown 		"0"
		is_manual 1
		update_health_uniform 		"1"


		DestructionLevels
		{
			DestructionLevel
			{
				health 								"80"
				destroy_state_change_effect_group 	"80_transition"
				destroy_comp_delay 					"0.5"
				destroy_comp_event 					"80_destroy"
				destroyed_state_effect_group 		"80_state"
