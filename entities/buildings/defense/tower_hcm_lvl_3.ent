	}

	SkeletonDesc
	{
		name "meshes/projectiles/tower_hcm_rocket_lvl_3"
	}

	EffectDesc
	{
		EffectGroup
		{			
			group "exhaust"
			enabled "0"
			
			Effects
			{
				Effect
				{
					blueprint "effects/weapons_explosive/rocket_projectile_very_big"
					bone "att_exhaust"
				}
			}
		}
	}	

	children
	{
		EntityBlueprint
		{
			RibbonComponent
			{
				material 			"ribbon/drone_trail_gold"
				update_bounds 		1
