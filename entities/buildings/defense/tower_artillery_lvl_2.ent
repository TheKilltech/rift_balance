EntityBlueprint  // tower_artillery_lvl_2
{
	name "buildings/defense/tower_artillery_lvl_2"
	base_blueprint 	"buildings/defense/tower_artillery"

	BuildingDesc
	{
		buildable			"0"
		name 				"tower_artillery_lvl_2"
		bp   				"buildings/defense/tower_artillery_lvl_2"
		category 			"defense"
		localization_id		"gui/hud/building_name/tower_artillery"
		description			"gui/hud/building_description/tower_artillery"
		menu_icon			"gui/hud/building_icons/tower_artillery_lvl2"
		require 			"headquarters"
		order				"10"
		check_connect		"1"
		type				"tower"
		overrides			"tower,wall,pipe_ground,pipe_connector_t,pipe_connector_x,pipe_corner,pipeline,pipe_straight_windowless"
		upgrade				//"buildings/defense/tower_artillery_lvl_3"
		exclude_terrain_types "magma_hot_ground,magma_very_hot_ground"
		condition			"NOT_BIOME"	
		condition_value		"caverns"			

		costs
		{
			BuildingCostInfo
			{
				name "default"
				building_time 6
				building_cost
				{
					carbonium 	"200"
					steel 		"600"
					uranium		"10"
				}
			}
		}
	}

	ResourceConverterDesc
	{
		in
		{
			GameplayResource
			{
				resource 	"energy"
				value 		"30"
			}
		}

		out
		{
		}

		priority 6
	}
	
	HealthDesc
	{
		max_health 					"750"
		health 						"750"
		regeneration 				"0"
		regeneration_cooldown 		"0"
		 is_manual 1
		update_health_uniform 		"1"


		DestructionLevels
		{
			DestructionLevel
			{
				health 								"66"
				destroy_comp_delay 					"0"
				destroy_comp_event 					"66_destroy"
				//destroyed_state_material 			"buildings/main/headquarters_dest_25"
				destroyed_state_effect_group 		"66_state"
			}
			DestructionLevel
			{
				health 								"33"
				destroy_comp_delay 					"0"
				destroy_comp_event 					"33_destroy"
				//destroyed_state_material 			"buildings/main/headquarters_dest_0"
				destroyed_state_effect_group 		"33_state"
			}
		}
	}

	MeshDesc
	{
		mesh "meshes/buildings/defense/tower_artillery_lvl_2.mesh"
		material "buildings/defense/tower_artillery_lvl_2"
	}

	SkeletonDesc
	{
		name "meshes/buildings/defense/tower_artillery_lvl_2"
	}

	WeaponItemDesc
	{
	}

	TurretDesc
	{
		target "ground_unit_artillery|ground_unit_large|ground_unit_medium|ground_unit"
		target_ignore "invisible"
		speed "300"
		aim_volume "SphericalAimVolume"
		{
			range_min "8"
			range_max "43"
			aiming_range "54"
		}

		aiming_cooldown "1"
		aiming_target_time "2"
		aiming_idle_angle "20"
		pitch "be_barrel"
		gravity_factor "8"
		yaw "be_turret"
		check_target_visibility "1"
		fog_of_war_filtering "1"
	}

	BurstWeaponComponent
	{
		WeaponMuzzles
		{
			WeaponMuzzle
			{
				attachment "att_muzzle"
				recoil_bone  "be_recoil"
				recoil_time   "0.35"
				recoil_offset   "1.0"
			}
		}

		WeaponAffector
		{
			emissive_time "0.35"
			emissive_factor "80" // "60"
			submesh_idx "1"
		}

		ammo_blueprint 			"buildings/defense/tower_artillery_projectile_lvl2"
		muzzle_flash_effect 	"effects/weapons_explosive/tower_rocket_fire_medium"

		burst_column_spacing 	"0"
		burst_rate 				"0"
		burst_column_angle 		"0"
	}

	EffectDesc
	{
		EffectBaseBlueprints
		{
			"buildings/effects_small_base"
		}
		////////////////////////MISC/////////////////////////
		EffectGroup
		{
			group "vismod"
			enabled "0"
			Effects
			{
				Effect
				{
					blueprint	"effects/buildings_and_machines/minipipes"
					bone 		"att_vismod_2"
					scale		"0.6 0.6 0.6"
				}
			}
		}	
		EffectGroup
		{
			group "lamp"
			enabled "0"

			Effects
			{
				Effect
				{
					blueprint "effects/buildings_and_machines/tower_white_searchlight"
					bone "att_muzzle"
					random_delay "3"
				}
			}
		}
	}
}

