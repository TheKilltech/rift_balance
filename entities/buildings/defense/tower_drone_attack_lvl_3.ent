EntityBlueprint  // tower_drone_attack_lvl_3
{
	name				"buildings/defense/tower_drone_attack_lvl_3"
	base_blueprint 		"buildings/defense/tower_drone_attack_lvl_2"

	BuildingDesc
	{
		buildable			"0"
		name 				"tower_drone_attack_lvl_3"
		bp   				"buildings/defense/tower_drone_attack_lvl_3"
		category 			"defense"
		localization_id		"gui/hud/building_name/tower_drone_attack_lvl3"
		description			"gui/hud/building_description/tower_drone_attack_lvl3"
		menu_icon			"gui/hud/building_icons/tower_drone_attack_lvl3"
		require 			"headquarters"
		building_group		"tower_drone_attack"
		buildable			"0"
		check_connect		"1"
		type				"tower"
		overrides			"tower,wall,pipe_ground,pipe_connector_t,pipe_connector_x,pipe_corner,pipeline,pipe_straight_windowless"
		exclude_terrain_types "magma_hot_ground,magma_very_hot_ground"

		costs
		{
			BuildingCostInfo
			{
				name "default"
				building_time 60
				building_cost
				{
					carbonium 	"800"
					alloys 		"1000"
					cobalt		"100"
				}
			}
		}
	}

	ResourceConverterDesc
	{
		in
		{
			GameplayResource
			{
				resource 	"energy"
				value 		"20"
			}
			
			GameplayResource
			{
				resource 	"ammo_tower_low_caliber_lvl3"
				value 		"0.01"
			}
			GameplayResource
			{
				resource 	"ammo_tower_energy_cell_lvl3"
				value 		"0.1"
			}
			
			GameplayResource
			{
				resource 	"reagent"
				value 		"2"
				family		"acid"
				attachment	"att_in_1"
			}
			
			GameplayResource
			{
				resource 	"sludge"
				value 		"15"
				family		"acid"
				attachment	"att_in_1"
			}
			
			GameplayResource
			{
				resource 	"nitric_acid"
				value 		"1"
				family		"acid"
				attachment	"att_in_1"
			}
		}

		out
		{
		}

		priority 6
	}

	LuaDesc
	{
		script "lua/buildings/drone_spawner_building.lua"
		
		database
		{
			cone_effect				string:"build_cone_3x3"
			cone_effect_sell 		string:"sell_big"

			drone_upkeep_modifier		float:"10.0"
			drone_full_search_interval	int:"5"
			drone_own_search_radius		float:"10"
			drone_search_radius			float:"60"
			drone_blueprint				string:"units/drones/drone_attack_acid_lvl_3"
			drone_attachments			string:"att_landing,att_landing_1,att_landing_2"
			drone_per_spot				int:"1"
			drone_visible_on_spot		int:"0"
		}
	}
	
	HealthDesc
	{
		max_health 					"1000"
		health 						"1000"
		regeneration 				"0"
		regeneration_cooldown 		"0"
		 is_manual 1
		update_health_uniform 		"1"

		DestructionLevels
		{
			DestructionLevel
			{
				health 								"80"
				destroy_state_change_effect_group 	"80_transition"
