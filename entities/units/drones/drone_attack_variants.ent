EntityBlueprint  // drone_projectile_energy
{
	name "items/weapons_enemy/drone_projectile_energy"
	base_blueprint "buildings/defense/tower_lightning_beam"

	LightningBeamComponent
	{
		range 					"16"

		on_enemy_hit_effect 	"effects/weapons_energy/lightning_gun_hit"

		type_mask				"ground_unit"
		aiming_angle			"360"

		idle_attachments
		{	
			IdString "att_lightning_1"
			IdString "att_lightning_2"
			IdString "att_lightning_3"
		}
	}
}

